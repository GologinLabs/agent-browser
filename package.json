{
  "name": "gologin-agent-browser-cli",
  "version": "0.2.0",
  "description": "Agent-native cloud browser automation CLI for Gologin",
  "main": "dist/cli.js",
  "types": "dist/lib/types.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples/agent-flow.sh"
  ],
  "bin": {
    "gologin-agent-browser": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "dev:cli": "tsx src/cli.ts",
    "dev:daemon": "tsx src/daemon/server.ts",
    "prepare": "npm run build",
    "test": "tsx --test tests/**/*.test.ts",
    "release:check": "npm run typecheck && npm test && npm run build && npm pack --dry-run",
    "prepublishOnly": "npm run release:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GologinLabs/agent-browser.git"
  },
  "homepage": "https://github.com/GologinLabs/agent-browser",
  "bugs": {
    "url": "https://github.com/GologinLabs/agent-browser/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "gologin",
    "agent",
    "cli",
    "cloud-browser",
    "anti-detect",
    "fingerprint",
    "proxy",
    "playwright",
    "browser"
  ],
  "author": "Gologin",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
